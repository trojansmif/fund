# Trojan SMIF — environment variables
# Set in Vercel → Project "trojansmif" → Settings → Environment Variables.
# Data sources layer: xlsx > csv > json > seed. Set one.

# --- RECOMMENDED: Excel on OneDrive/SharePoint ---
# Direct-download URL to the SMIF Portfolio Tracker .xlsx.
# OneDrive: share as "Anyone with the link" → copy link → append ?download=1
#   e.g. https://1drv.ms/x/s!AbCdEf123...?download=1
# SharePoint: share link → open settings → "Direct download" option, or
#   append &download=1 to the share URL.
PORTFOLIO_XLSX_URL=

# --- Alternative: Google Sheets (CSV) ---
PORTFOLIO_HOLDINGS_CSV=
PORTFOLIO_META_CSV=

# --- Advanced: custom JSON endpoint (Snapshot shape) ---
PORTFOLIO_DATA_URL=

# --- SharePoint link for the "Open document library" button on /portfolio ---
SHAREPOINT_DOCS_URL=

# --- LinkedIn company page (already wired in code) ---
LINKEDIN_URL=https://www.linkedin.com/company/113424338
